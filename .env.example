# ── MySQL ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=ticket_manager

# ── Servidor ──────────────────────────────────────────────────────
PORT=8000
NODE_ENV=production

# ── Dominios ──────────────────────────────────────────────────────
# Producción: https://solucionespisox.com
FRONTEND_URL=https://solucionespisox.com
API_URL=https://api.solucionespisox.com

# ── Uploads ───────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Google Cloud Vision ───────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# ── Debug (opcional) ──────────────────────────────────────────────
DEBUG=false
